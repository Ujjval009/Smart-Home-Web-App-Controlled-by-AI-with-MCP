│   ├── routes/
│   │   ├── __init__.py
│   │   ├── devices.py           # REST endpoints for devices
│   │   └── websocket.py         # WebSocket handler
│   └── models.py                # Pydantic models (request/response)
│
├── database/                    # Database layer
│   ├── __init__.py
